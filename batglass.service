[Unit]
Description=BatGlass smart glasses daemon
After=network.target

[Service]
Type=simple
User=aloysius
WorkingDirectory=/home/aloysius/batglass
Environment=PYTHONUNBUFFERED=1
Environment=PATH=/home/aloysius/batglass/llama.cpp/build/bin:/home/aloysius/batglass/whisper.cpp/build/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStartPre=-/usr/bin/pkill -u aloysius -f "/home/aloysius/batglass/.venv/bin/python -m buttons.__main__"
ExecStart=/home/aloysius/batglass/run_buttons.sh
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
